{
    "name": "jtl-scx/api-base-client",
    "type": "library",
    "description": "SCX-API Base Client",
    "license": "MIT",
    "require": {
        "php": "8.3.* || 8.4.* || 8.5.*",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.9 || ^8.0",
        "guzzlehttp/uri-template": "^1.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.75",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.5"
    },
    "autoload": {
        "psr-4": {
            "JTL\\SCX\\Client\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JTL\\SCX\\Client\\": "tests/"
        }
    },
    "scripts": {
        "phpcs": [
            "vendor/bin/php-cs-fixer fix --config=./.php-cs-fixer.dist.php"
        ],
        "phpcs-dry": [
            "vendor/bin/php-cs-fixer fix --config=./.php-cs-fixer.dist.php --dry-run"
        ],
        "phpstan": [
            "vendor/bin/phpstan analyse"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
